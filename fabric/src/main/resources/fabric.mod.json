{
  "schemaVersion": 1,
  "id": "config-backuper",
  "version": "${version}",
  "name": "Config Backuper",
  "description": "A simple Minecraft mod that automatically backs up game configurations, supports configurable backup paths and WebDAV cloud backup.",
  "authors": [
    "Akiyy Dev"
  ],
  "contact": {
    "sources": "https://github.com/Akiyy-dev/Config-Cloud-Backuper"
  },
  "license": "MIT",
  "icon": "assets/config-backuper/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.naocraftlab.configbackuper.FabricModInitializer"
    ],
    "client": [
      "com.naocraftlab.configbackuper.client.ConfigBackuperClient"
    ],
    "modmenu": [
      "com.naocraftlab.configbackuper.config.ModMenuIntegration"
    ]
  },
  "mixins": [],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.1",
    "fabric-api": "*",
    "java": ">=17"
  },
  "suggests": {
    "cloth-config": "*",
    "modmenu": "*"
  }
}
